DJANGO_SECRET_KEY=change-me-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Development default: sqlite. Production recommendation: postgresql.
# Supported: sqlite, postgresql, mysql.
DATABASE_ENGINE=sqlite
DATABASE_NAME=db.sqlite3
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=127.0.0.1
DATABASE_PORT=

# Optional single URL alternative, useful for PostgreSQL deployments.
# Do not commit real passwords. Keep real DATABASE_URL only in local .env/server secret store.
# DATABASE_URL=postgres://intermilan_user:<PASSWORD_NOT_FOR_REPO>@localhost:5432/intermilan_db

MEDIA_ROOT=
STATIC_ROOT=

# Large upload limits for Paket SPM ZIP/PDF. Files above FILE_UPLOAD_MAX_MEMORY_SIZE use temp files.
MAX_UPLOAD_SIZE_MB=2048
MAX_FOLDER_UPLOAD_SIZE_MB=2048
MAX_ZIP_SIZE_MB=2048
MAX_ZIP_TOTAL_UNCOMPRESSED_MB=5000
MAX_ZIP_FILES=1000
MAX_UPLOAD_FILES=1000
MAX_PDF_PAGES_PREVIEW=3
MAX_OCR_SECONDS_PER_FILE=90

# Optional read-only source paths for import commands.
LEGACY_SQLITE_PATH=C:\Users\muall\Documents\Magang BPS\intermilan%20testing\INTERMILAN 29-06\instance\sp2d_kk1300.sqlite
EXCEL_SEED_PATH=C:\Users\muall\Documents\Magang BPS\drive-download-20260615T061835Z-3-001

# Google Drive archive integration. Keep real credentials only in local .env/server secret store.
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=
GOOGLE_DRIVE_CREDENTIALS_JSON=
GOOGLE_DRIVE_UPLOAD_MODE=service_account

# OCR scan fallback. Python packages are in requirements; Windows still needs Tesseract and Poppler binaries.
OCR_ENABLED=True
OCR_SERVER_MODE=local

# Alur engine: text (Level 1), tesseract (Level 2), paddleocr (Level 3)
OCR_ENGINE_ORDER=text,tesseract,paddleocr

# Dokumen INTERMILAN hampir pasti scan kertas — selalu render PDF ke image untuk OCR
# Aktifkan ini agar Tesseract dipanggil meski native text ada
OCR_FORCE_IMAGE_FOR_SCANNED_DOCS=true

# Aktifkan/nonaktifkan setiap layer
OCR_ENABLE_TEXT_EXTRACTION=true
OCR_ENABLE_TESSERACT=true
OCR_ENABLE_PADDLEOCR=true

# Tesseract: path binary (Windows), panjang minimal text, confidence minimal
# OCR_TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
OCR_TESSERACT_MIN_TEXT_LENGTH=50
OCR_TESSERACT_MIN_CONFIDENCE=60

# PaddleOCR: confidence minimal (hanya dipakai jika OCR_ENABLE_PADDLEOCR=true)
OCR_PADDLEOCR_MIN_CONFIDENCE=60
OCR_PADDLEOCR_LANG=en
OCR_PADDLEOCR_DEVICE=cpu
OCR_PADDLEOCR_DOC_ORIENTATION=true
OCR_PADDLEOCR_DOC_UNWARPING=false
OCR_PADDLEOCR_TEXTLINE_ORIENTATION=true

# Threshold binarisasi image (eksperimental, false = off)
OCR_ENABLE_THRESHOLD=false

# Batas halaman preview (bukan batas OCR)
OCR_MAX_PAGES_PREVIEW=3

# Batas teks native minimal (karakter) sebelum dianggap perlu OCR
OCR_NATIVE_MIN_CHARS=120
OCR_NATIVE_MIN_SCORE=18

# Cloud OCR (jangan aktifkan tanpa konfigurasi khusus)
OCR_ENABLE_CLOUD=false
OCR_CLOUD_PROVIDER=

# Optional cloud OCR placeholders. Keep secrets only in local .env/server secret store.
GOOGLE_DOCUMENT_AI_ENABLED=false
GOOGLE_DOCUMENT_AI_PROJECT_ID=
GOOGLE_DOCUMENT_AI_LOCATION=
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
AZURE_DOCUMENT_INTELLIGENCE_ENABLED=false
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
